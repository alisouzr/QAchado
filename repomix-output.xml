// app/services/vulnerabilityService.ts

const USE_MOCK = false; // <--- BACKEND DEV: Mude para false
const API_BASE_URL = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:3001/api';



export interface VulnerabilityData {
  id?: string;
  cve?: string;
  title: string;
  description: string;
  severity: string;
  projetoId: string;
  recomendacao: string;
  comentarios: string;
  reportadoPor: string;
  assigneeInitials?: string;
  status?: 'ABERTO' | 'ATRIBUÍDO' | 'EM PROGRESSO' | 'PRONTO PARA RETESTE' | 'CONCLUÍDO';
}

export const vulnerabilityService = {
  
  async create(data: VulnerabilityData) {
      if (!USE_MOCK) {
        // Dicionário mapeador de severidade para o Enum do Prisma (HIGH, MEDIUM, LOW)
        const severityMap: Record<string, string> = {
          'Baixa': 'LOW',
          'Média': 'MEDIUM',
          'Alta': 'HIGH',
          'Crítica': 'CRITICAL'
        };

        // Montagem estrita do payload correspondendo linha por linha ao destructuring do Express
        const payload = {
          title: data.title,
          description: data.description,
          // Converte o texto da UI (ex: "Alta") para o padrão Enum do Prisma ("HIGH")
          severity: severityMap[data.severity] || data.severity.toUpperCase(), 
          projectId: data.projetoId, // -> CORREÇÃO AQUI: Alinhado com o backend (req.body.projectId)
          recommendation: data.recomendacao, // -> Alinhado com o backend (req.body.recommendation)
          cve: data.cve || undefined
        };

        const response = await fetch(`${API_BASE_URL}/vulnerabilidades`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          throw new Error(errorData.error || 'Falha ao criar vulnerabilidade.');
        }
        return await response.json();
      }

      // Fluxo do MOCK original (permanece 100% intocado)
      const novaVuln = { 
        ...data, 
        id: Date.now().toString(), 
        cve: data.cve || `CVE-2026-${Math.floor(Math.random() * 9000) + 1000}`,
        status: 'ABERTO' as const,
        assigneeInitials: 'ND'
      };
      const falhasSalvas = JSON.parse(localStorage.getItem('vuln_db') || '[]');
      falhasSalvas.push(novaVuln);
      localStorage.setItem('vuln_db', JSON.stringify(falhasSalvas));
      return novaVuln;
    },

  async getById(id: string) {
    if (!USE_MOCK) {
      const response = await fetch(`${API_BASE_URL}/vulnerabilidades/${id}`, {
        credentials: 'include' // -> ADICIONADO
      });
      return await response.json();
    }
    const falhas = JSON.parse(localStorage.getItem('vuln_db') || '[]');
    return falhas.find((f: VulnerabilityData) => f.id === id);
  },

  async getByProject(projectId: string) {
    if (!USE_MOCK) {
      const response = await fetch(`${API_BASE_URL}/projetos/${projectId}/vulnerabilidades`, {
        credentials: 'include' // -> ADICIONADO
      });
      return await response.json();
    }
    const falhas = JSON.parse(localStorage.getItem('vuln_db') || '[]');
    return falhas.filter((f: VulnerabilityData) => f.projetoId === projectId);
  },

  async updateStatus(id: string, newStatus: string) {
    if (!USE_MOCK) {
      const response = await fetch(`${API_BASE_URL}/vulnerabilidades/${id}/status`, {
        method: 'PATCH', 
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include', // -> ADICIONADO
        body: JSON.stringify({ status: newStatus }),
      });
      return await response.json();
    }

    const falhas = JSON.parse(localStorage.getItem('vuln_db') || '[]');
    const atualizadas = falhas.map((f: any) => f.id === id ? { ...f, status: newStatus } : f);
    localStorage.setItem('vuln_db', JSON.stringify(atualizadas));
  },

  async update(id: string, data: Partial<VulnerabilityData>) {
    if (!USE_MOCK) {
      const response = await fetch(`${API_BASE_URL}/vulnerabilidades/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include', // -> ADICIONADO
        body: JSON.stringify(data),
      });
      return await response.json();
    }

    const falhas = JSON.parse(localStorage.getItem('vuln_db') || '[]');
    const atualizadas = falhas.map((f: any) => f.id === id ? { ...f, ...data } : f);
    localStorage.setItem('vuln_db', JSON.stringify(atualizadas));
  },

  // Busca APENAS as falhas com status "ABERTO" (Independente do projeto)
  async getOpenVulnerabilities() {
    if (!USE_MOCK) {
      const response = await fetch(`${API_BASE_URL}/vulnerabilidades/abertas`, {
        credentials: 'include' // -> ADICIONADO
      });
      return await response.json();
    }
    const falhas = JSON.parse(localStorage.getItem('vuln_db') || '[]');
    return falhas.filter((f: VulnerabilityData) => f.status === 'ABERTO');
  },

  // Atribui a falha a um dev e muda o status automaticamente
  async assignToDev(vulnId: string, devInitials: string) {
    if (!USE_MOCK) {
      const response = await fetch(`${API_BASE_URL}/vulnerabilidades/${vulnId}/atribuir`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include', // -> ADICIONADO
        body: JSON.stringify({ assigneeInitials: devInitials, status: 'ATRIBUÍDO' }),
      });
      return await response.json();
    }

    const falhas = JSON.parse(localStorage.getItem('vuln_db') || '[]');
    const atualizadas = falhas.map((f: any) => 
      f.id === vulnId ? { ...f, status: 'ATRIBUÍDO', assigneeInitials: devInitials } : f
    );
    localStorage.setItem('vuln_db', JSON.stringify(atualizadas));
  },
  
  async getByAssignee(initials: string) {
    if (!USE_MOCK) {
      const response = await fetch(`${API_BASE_URL}/vulnerabilidades/dev/${initials}`, {
        credentials: 'include' // -> ADICIONADO
      });
      if (!response.ok) throw new Error('Falha ao buscar atribuições.');
      return await response.json();
    }

    const falhas = JSON.parse(localStorage.getItem('vuln_db') || '[]');
    // Retorna as falhas do dev, ocultando as que já foram concluídas pelo QA
    return falhas.filter((f: VulnerabilityData) => 
      f.assigneeInitials === initials && f.status !== 'CONCLUÍDO'
    );
  }
};
</file>


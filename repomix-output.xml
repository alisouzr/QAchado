import { PrismaClient } from '@prisma/client';
import { authLocalStorage } from './auth-context.js';

const basePrisma = new PrismaClient();

export const prisma = basePrisma.$extends({
  query: {
    vulnerability: {
      async update({ model, operation, args, query }) {
        const context = authLocalStorage.getStore();
        const userId = context?.userId || 'SYSTEM'; // Fallback se alterado por script/cron

        // 1. Busca o estado atual antes de atualizar para saber o status antigo
        const previousState = await basePrisma.vulnerability.findUnique({
          where: { id: args.where.id },
          select: { status: true }
        });

        // 2. Executa a atualização original
        const result = await query(args);

        // 3. Verifica se houve mudança de status
        if (previousState && previousState.status !== result.status) {
          await basePrisma.auditLog.create({
            data: {
              userId: userId,
              action: 'VULNERABILITY_STATUS_CHANGE',
              target: 'Vulnerability',
              targetId: result.id,
              details: `Status alterado de "${previousState.status}" para "${result.status}"`
            }
          });
        }

        return result;
      }
    }
  }
});

import type { Request, Response } from 'express';
import { prisma } from '../lib/prisma.js';
import { Severity, Status, Role } from '@prisma/client';
import { AIService } from '../services/ai.service.js'; // Ajuste o caminho se necessário

// 1. CRIAR VULNERABILIDADE (INTEGRADO COM IA)
export const createVulnerability = async (req: Request, res: Response) => {
  let { title, description, severity, recommendation, projectId, cve, cwe, owaspTop10, tagIds } = req.body;
  const reporterId = req.user!.id;

  // Modificado: validação defensiva aceita que recommendation venha em branco para que a IA possa gerar
  if (!title || !description || !severity || !projectId) {
    return res.status(400).json({ error: 'Campos obrigatórios ausentes.' });
  }

  try {
    // Se o usuário não providenciou uma recomendação de correção, recorre à Inteligência Artificial
    if (!recommendation || String(recommendation).trim() === '') {
      console.log(`[IA] Gerando recomendação automatizada para: "${title}"`);
      const iaResponse = await AIService.obterRemediacao(title, description);
      recommendation = iaResponse || 'Tratativa e remediação padrão recomendada pela equipe técnica.';
    }

    const vulnerability = await prisma.vulnerability.create({
      data: {
        title,
        description,
        severity: severity as Severity,
        recommendation, // Agora com garantia de conteúdo populado (Manualmente ou via IA)
        projectId,
        reportedById: reporterId,
        cve,
        cwe,
        owaspTop10,
        // Cria os vínculos N:M na tabela intermediária se houver tags
        tags: tagIds && Array.isArray(tagIds) ? {
          create: tagIds.map((tagId: string) => ({ tagId }))
        } : undefined
      },
      include: { tags: { include: { tag: true } } }
    });

    // Log de Auditoria
    await prisma.auditLog.create({
      data: {
        userId: reporterId,
        action: 'VULNERABILITY_CREATE',
        target: 'Vulnerability',
        targetId: vulnerability.id,
        details: `Vulnerabilidade "${title}" reportada no projeto ${projectId}.`
      }
    });

    return res.status(201).json(vulnerability);
  } catch (error) {
    console.error(error);
    return res.status(500).json({ error: 'Erro ao registrar vulnerabilidade.' });
  }
};

// 2. LISTAR VULNERABILIDADES COM FILTROS AVANÇADOS E ISOLAMENTO DE DEV
export const getVulnerabilities = async (req: Request, res: Response) => {
  const { status, severity, projectId, tagId, assignedToId } = queryParamsFix(req.query);
  const { id: userId, role } = req.user!;

  // Construção do objeto de filtros dinâmicos do Prisma (Where)
  const whereClause: any = {};

  if (status) whereClause.status = status as Status;
  if (severity) whereClause.severity = severity as Severity;
  if (projectId) whereClause.projectId = projectId;
  if (assignedToId) whereClause.assignedToId = assignedToId;
  
  // Filtro por Tags (Relacionamento N:M)
  if (tagId) {
    whereClause.tags = {
      some: { tagId: tagId }
    };
  }

  // BARREIRA DO RBAC: Se for DEV, ele só pode ver registros dos seus projetos atribuídos
  if (role === Role.DEV) {
    const userProjects = await prisma.projectDev.findMany({
      where: { userId },
      select: { projectId: true }
    });
    const allowedProjectIds = userProjects.map(p => p.projectId);

    if (projectId && !allowedProjectIds.includes(projectId)) {
      return res.status(403).json({ error: 'Acesso negado: Você não possui acesso a este projeto.' });
    }

    // Injeta a restrição global de escopo caso ele não tenha filtrado por um projeto específico
    whereClause.projectId = { in: allowedProjectIds };
  }

  try {
    const vulnerabilities = await prisma.vulnerability.findMany({
      where: whereClause,
      include: {
        project: { select: { id: true, name: true } },
        reportedBy: { select: { id: true, name: true, email: true } },
        tags: { include: { tag: true } }
      },
      orderBy: { createdAt: 'desc' }
    });

    return res.json(vulnerabilities);
  } catch (error) {
    return res.status(500).json({ error: 'Erro ao buscar listagem de vulnerabilidades.' });
  }
};

// 3. ATUALIZAR VULNERABILIDADE
export const updateVulnerability = async (req: Request, res: Response) => {
  const { id } = req.params;
  const { status, assignedToId, severity, title, description, recommendation } = req.body;
  const { id: userId, role } = req.user!;

  // Garante que o ID da URL seja tratado como string única
  const vulnerabilityId = id as string;

  try {
    // Busca o registro atual para validar escopo do DEV
    const currentVuln = await prisma.vulnerability.findUnique({ 
      where: { id: vulnerabilityId } 
    });
    
    if (!currentVuln) {
      return res.status(404).json({ error: 'Vulnerabilidade não encontrada.' });
    }

    // BARREIRA DO RBAC: Se for DEV, valida se o achado pertence a um de seus projetos
    if (role === Role.DEV) {
      const access = await prisma.projectDev.findUnique({
        where: { projectId_userId: { projectId: currentVuln.projectId, userId } }
      });
      if (!access) {
        return res.status(403).json({ error: 'Acesso negado: Este achado pertence a um projeto fora do seu escopo.' });
      }
    }

    // Tratamento estrito de tipos para evitar o erro 'string | string[]' no Prisma
    const updatedStatus = typeof status === 'string' ? (status as Status) : undefined;
    const updatedSeverity = typeof severity === 'string' ? (severity as Severity) : undefined;
    const updatedTitle = typeof title === 'string' ? (title as string) : undefined;
    const updatedDescription = typeof description === 'string' ? (description as string) : undefined;
    const updatedRecommendation = typeof recommendation === 'string' ? (recommendation as string) : undefined;
    
    // Resolve o erro do 'assignedToId' limpando a possibilidade de array
    let updatedAssignedToId: string | null | undefined = undefined;
    if (typeof assignedToId === 'string') {
      updatedAssignedToId = assignedToId as string;
    } else if (assignedToId === null) {
      updatedAssignedToId = null; // Permite desatribuir a tarefa enviando null
    }

    // Atualização parcial dinâmica no banco
    const updatedVuln = await prisma.vulnerability.update({
      where: { id: vulnerabilityId },
      data: {
        status: updatedStatus,
        assignedToId: updatedAssignedToId,
        severity: updatedSeverity,
        title: updatedTitle,
        description: updatedDescription,
        recommendation: updatedRecommendation,
      }
    });

    // Resolve o erro do prisma.auditLog.create convertendo os dados explicitamente para String
    const auditDetails = JSON.stringify({ 
      statusAntigo: String(currentVuln.status), 
      statusNovo: String(updatedVuln.status), 
      designado: updatedAssignedToId ? String(updatedAssignedToId) : 'Nenhum' 
    });

    // Log de Auditoria para Rastreabilidade (Tipado de forma ultra-estrita)
    await prisma.auditLog.create({
      data: {
        userId: userId as string,
        action: 'VULNERABILITY_UPDATE',
        target: 'Vulnerability',
        targetId: vulnerabilityId,
        details: auditDetails // Agora o tipo é garantido como uma string JSON limpa
      }
    });

    return res.json(updatedVuln);
  } catch (error) {
    console.error(error);
    return res.status(500).json({ error: 'Erro ao atualizar a vulnerabilidade.' });
  }
};

// 4. DELETAR VULNERABILIDADE (Apenas Admin/QA)
export const deleteVulnerability = async (req: Request, res: Response) => {
  // Fazemos o casting explícito de tipo para 'string'
  const vulnerabilityId = req.params.id as string;

  // Validação defensiva rápida em runtime
  if (!vulnerabilityId) {
    return res.status(400).json({ error: 'ID da vulnerabilidade inválido ou ausente.' });
  }

  try {
    // Passamos a variável limpa para o Prisma
    await prisma.vulnerability.delete({ 
      where: { id: vulnerabilityId } 
    });
    
    return res.status(204).send();
  } catch (error) {
    console.error(error);
    return res.status(500).json({ error: 'Erro ao remover vulnerabilidade.' });
  }
};

// Auxiliar para mitigar tipagens parciais do Express Query String
function queryParamsFix(query: any) {
  return {
    status: typeof query.status === 'string' ? (query.status as string) : undefined,
    severity: typeof query.severity === 'string' ? (query.severity as string) : undefined,
    projectId: typeof query.projectId === 'string' ? (query.projectId as string) : undefined,
    tagId: typeof query.tagId === 'string' ? (query.tagId as string) : undefined,
    assignedToId: typeof query.assignedToId === 'string' ? (query.assignedToId as string) : undefined,
  };
}
